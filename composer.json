{
    "name": "xcesaralejandro/canvasoauth",
    "description": "This package provides a simple integration for oauth between canvas and laravel.",
    "license": "MIT",
    "authors": [
        {
            "name": "César Alejandro Mora Cid",
            "email": "cesar.mcid@gmail.com"
        }
    ],
    "require": {
        "php": "^8.0",
        "guzzlehttp/guzzle": "^7.15.0"
    },
    "autoload": {
        "psr-4": {
            "xcesaralejandro\\canvasoauth\\": "src/",
            "xcesaralejandro\\canvasoauth\\Http\\": "Http/"
        }
    },
    "require-dev": {
        "orchestra/testbench": "^11.1.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "xcesaralejandro\\canvasoauth\\Providers\\CanvasOauthServiceProvider"
            ],
            "aliases": {
                "CanvasOauth": "xcesaralejandro\\canvasoauth\\Facades\\CanvasOauth"
            }
        }
    }
}